# =============================================================================
# campslinger - example environment file for the Telegram bot operator
# =============================================================================
# Copy to .env (gitignored) and load before starting campslinger_tg.py:
#   set -a; source .env; set +a; python3 campslinger_tg.py
# Or reference it from systemd: EnvironmentFile=/path/to/.env
#
# The CLI (campslinger.py) does not read these variables (flags only).
# =============================================================================

# --- Required ---------------------------------------------------------------

# Bot token from @BotFather. Treat as a secret. Revoke and reissue if leaked.
TELEGRAM_BOT_TOKEN=

# Comma-separated numeric Telegram user IDs (NOT @usernames) allowed to use
# the bot. Find yours with @userinfobot. Example: 123456789,987654321
TELEGRAM_ALLOWED_USER_IDS=

# --- Optional ---------------------------------------------------------------

# Append-only JSON audit log path. Empty / unset uses ./campslinger_telegram_audit.log
# In production prefer an absolute path with restrictive permissions, e.g.:
#   CAMPSLINGER_AUDIT_LOG=/var/log/campslinger/audit.log
CAMPSLINGER_AUDIT_LOG=

# --- Optional: wizard draft persistence -------------------------------------
# When enabled, an in-progress /monitor wizard is saved to disk so a user can
# resume it after a bot restart (tap 📡 Monitor to resume). Drafts expire after
# 7 days. Twilio secrets are NEVER written to draft files. Off by default.
#   CAMPSLINGER_WIZARD_PERSIST=1
CAMPSLINGER_WIZARD_PERSIST=
# Directory for draft files. Empty / unset uses ./campslinger_wizard_drafts
CAMPSLINGER_WIZARD_DRAFT_DIR=

# --- Optional: job persistence (survive reboots) ----------------------------
# When enabled, running jobs are saved to disk and automatically restored on
# bot startup. Twilio secrets are NEVER persisted.
#   CAMPSLINGER_JOB_PERSIST=1
CAMPSLINGER_JOB_PERSIST=
# Path to active-jobs JSON file. Empty / unset uses ./campslinger_active_jobs.json
CAMPSLINGER_JOB_STORE_PATH=

# --- Optional: job history (browse & re-run past jobs) ----------------------
# When enabled, finished jobs are archived to a JSONL file, browsable via
# the 📂 History button in /menu. Independent of job persistence above —
# enable either or both. Twilio secrets are NEVER written.
#   CAMPSLINGER_JOB_HISTORY=1
CAMPSLINGER_JOB_HISTORY=
# Path to finished-job archive (JSONL). Empty / unset uses ./campslinger_job_archive.jsonl
CAMPSLINGER_JOB_ARCHIVE_PATH=

# --- Optional: max concurrent jobs ------------------------------------------
# Also settable via --max-concurrent CLI flag (flag wins if both are set).
# Default: 3
CAMPSLINGER_MAX_CONCURRENT=

# --- Optional: SMS / Twilio defaults (server-wide) --------------------------
# When all four are set, users can toggle SMS on any job without entering
# credentials in the Telegram wizard. Per-job wizard values override env.
# Credentials are never written to the audit log.

CAMPSLINGER_TWILIO_SID=
CAMPSLINGER_TWILIO_AUTH_TOKEN=
CAMPSLINGER_TWILIO_NUMBER=
CAMPSLINGER_MY_PHONE_NUMBER=

# =============================================================================
# What is NOT an environment variable (intentional)
# =============================================================================
# Remote Chrome host  -> operator process flags --rip / --rp on the bot
#                        (or --rip / --rp on campslinger.py); NOT env vars.
# Booking URL         -> per-job, sent in chat or with /monitor <url>.
# =============================================================================
