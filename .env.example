# =============================================================================
# campslinger - example environment file for the Telegram bot operator
# =============================================================================
# Copy to .env (gitignored) and load before starting campslinger_tg.py:
#   set -a; source .env; set +a; python3 campslinger_tg.py
# Or reference it from systemd: EnvironmentFile=/path/to/.env
#
# This file ONLY documents the variables campslinger_tg.py reads. The CLI
# (campslinger.py) takes everything via flags and does not read environment.
# =============================================================================

# --- Required ---------------------------------------------------------------

# Bot token from @BotFather. Treat as a secret. Revoke and reissue if leaked.
TELEGRAM_BOT_TOKEN=

# Comma-separated numeric Telegram user IDs (NOT @usernames) allowed to use
# the bot. Find yours with @userinfobot. Example: 123456789,987654321
TELEGRAM_ALLOWED_USER_IDS=

# --- Optional ---------------------------------------------------------------

# Append-only JSON audit log path. Empty / unset uses ./campslinger_telegram_audit.log
# In production prefer an absolute path with restrictive permissions, e.g.:
#   CAMPSLINGER_AUDIT_LOG=/var/log/campslinger/audit.log
CAMPSLINGER_AUDIT_LOG=

# =============================================================================
# What is NOT an environment variable (intentional)
# =============================================================================
# Twilio credentials  -> per-job, set in the Telegram wizard's SMS submenu
#                        OR passed as CLI flags (--tsid --tat --tn --mpn).
# Remote Chrome host  -> operator process flags --rip / --rp on the bot
#                        (or --rip / --rp on campslinger.py); NOT env vars.
# Max concurrent jobs -> --max-concurrent on campslinger_tg.py.
# Booking URL         -> per-job, sent in chat or with /monitor <url>.
# =============================================================================
